# Lokální test: zkopíruj jako .streamlit/secrets.toml (soubor je v .gitignore).
# Streamlit Cloud: stejný obsah vlož v Deployments → tvoje app → ⋮ → Settings → Secrets.

[pipedrive]
api_token = "váš-api-token"
domain = "vasafirma.pipedrive.com"
category_field_key = "klíč-custom-pole-kategorie"
# volitelné — režim měsíce dealu, viz vividbooks_ops
deal_month_date_field = "close_time"
