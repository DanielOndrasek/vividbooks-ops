# --- HTTP server ---
# Port, na kterém worker poslouchá (Fly.io interní). Veřejně se vystaví přes Caddy/Fly TLS.
PORT=8080
# Pokud true, worker odpovídá fixturou bez volání RealityMIX (lokální vývoj bez whitelistu).
MOCK_MODE=false
# Volitelně: comma-separated CIDR allowlist pro callery (např. Supabase egress IP).
# Pokud prázdné, kontroluje se pouze INTERNAL_EGRESS_TOKEN.
ALLOWED_CALLER_CIDRS=

# --- Sdílené tajemství mezi Supabase Edge Function a workerem ---
# Náhodný řetězec ≥ 32 znaků; nastavit i v Supabase secrets jako INTERNAL_EGRESS_TOKEN.
INTERNAL_EGRESS_TOKEN=

# --- RealityMIX (DALTEN media s.r.o.) ---
# ID realitní kanceláře (rkId), heslo a softwarový klíč. Whitelist IP je vázán na SW klíč.
REALITYMIX_RK_ID=
REALITYMIX_RK_PASSWORD=
REALITYMIX_SW_KEY=
# XML-RPC endpoint (port 443). Doporučená HTTPS varianta.
REALITYMIX_RPC_URL=https://realitymix.cz/import/rpc/
# Timeout pro jednotlivá RPC volání (ms).
REALITYMIX_RPC_TIMEOUT_MS=15000
