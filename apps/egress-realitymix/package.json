{
  "name": "@vividbooks/egress-realitymix",
  "version": "0.1.0",
  "private": true,
  "description": "Egress worker with a fixed public IPv4 that proxies RealityMIX XML-RPC import API for Supabase Edge Functions.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "xmlrpc": "^1.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/xmlrpc": "^1.3.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
