{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run vercel-build",
  "crons": [
    {
      "path": "/api/jobs/poll-email",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/jobs/process-documents",
      "schedule": "30 6 * * *"
    }
  ]
}
