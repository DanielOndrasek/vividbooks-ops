// Normalizovaný model: Email → Document → Invoice | PaymentProof
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  APPROVER
  VIEWER
}

enum EmailStatus {
  PENDING
  PROCESSED
  ERROR
}

enum DocumentType {
  UNCLASSIFIED
  INVOICE
  PAYMENT_RECEIPT
  UNKNOWN
}

enum DocumentStatus {
  NEW
  PARSED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  UPLOAD_FAILED
  NEEDS_REVIEW
  RECEIVED
  STORED
  ERROR
}

/// Stav odeslání dokladu do POHODY (mServer / XML).
enum PohodaExportStatus {
  NONE
  PENDING
  EXPORTED
  FAILED
}

/// Typ skladového pohybu: příjem, výdej nebo korekce stavu (inventura).
enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

/// Původ skladové položky: ruční evidence nebo synchronizace z externího systému (Fulfillment.cz).
enum InventorySource {
  MANUAL
  FULFILLMENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  createdAt     DateTime  @default(now())

  accounts                Account[]
  sessions                Session[]
  auditLogs               AuditLog[]
  approvedInvoices        Invoice[]                  @relation("InvoiceApprovedBy")
  commissionSnapshots     CommissionMonthSnapshot[]
  inventoryMovements      InventoryMovement[]        @relation("InventoryMovementCreatedBy")
}

/// Uložený výsledek výpočtu provizí za kalendářní měsíc (jeden záznam na year+month).
model CommissionMonthSnapshot {
  id                 String   @id @default(cuid())
  year               Int
  month              Int
  computedAt         DateTime @default(now())
  computedByUserId   String?
  computedBy         User?    @relation(fields: [computedByUserId], references: [id], onDelete: SetNull)
  payload            Json

  @@unique([year, month])
  @@index([year])
}

/// Měsíční fixní odměna obchodníka (shoda `ownerLabel` s jménem z Pipedrive / provizí), platná pro daný kalendářní rok.
model SalesPersonMonthlyFixed {
  id         String   @id @default(cuid())
  year       Int
  ownerLabel String
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @default("CZK")
  note       String?  @db.Text
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([year])
  @@index([active])
  @@index([ownerLabel])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Email {
  id             String      @id @default(cuid())
  gmailMessageId String      @unique
  subject        String
  /// Kompletní hlavička From (pro zobrazení).
  sender         String
  /// Rozpoznaná e-mailová adresa odesílatele (pro filtry a logy).
  senderEmail    String?
  receivedAt     DateTime
  processedAt    DateTime?
  status         EmailStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  documents Document[]

  @@index([senderEmail])
}

model Document {
  id                        String         @id @default(cuid())
  emailId                   String
  email                     Email          @relation(fields: [emailId], references: [id], onDelete: Cascade)
  gmailAttachmentId         String
  originalFilename          String
  mimeType                  String
  contentHash               String?
  extractedText             String?        @db.Text
  classificationConfidence Float?
  documentType              DocumentType   @default(UNCLASSIFIED)
  status                    DocumentStatus @default(NEW)
  parseError                String?        @db.Text
  localFilePath             String?
  aiRawResponse             String?        @db.Text
  needsManualReview         Boolean        @default(false)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  invoice      Invoice?
  paymentProof PaymentProof?

  @@unique([emailId, gmailAttachmentId])
  @@unique([contentHash])
  @@index([status])
  @@index([documentType])
}

model Invoice {
  id                   String    @id @default(cuid())
  documentId           String    @unique
  document             Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  supplierName         String?
  amountWithoutVat       Decimal?  @db.Decimal(12, 2)
  amountWithVat        Decimal?  @db.Decimal(12, 2)
  dueDate              DateTime?
  invoiceNumber        String?
  currency             String    @default("CZK")
  issueDate            DateTime?
  supplierICO          String?
  supplierDIC          String?
  supplierStreet       String?
  supplierCity         String?
  supplierZip          String?
  supplierCountry      String?
  variableSymbol       String?
  constantSymbol       String?
  specificSymbol       String?
  vatAmount            Decimal?  @db.Decimal(12, 2)
  vatRate              Decimal?  @db.Decimal(5, 2)
  bankAccount          String?
  iban                 String?
  domesticAccount      String?
  bic                  String?
  /// Např. STANDARD_INVOICE, PROFORMA, CREDIT_NOTE — volné z AI / ruční úprava.
  documentKind         String?
  /// Řádky faktury z AI (JSON pole); prázdné = jen souhrnné částky.
  invoiceLines         Json?
  missingStructuredLines Boolean @default(false)
  extractionConfidence Float?

  approvedByUserId String?
  approvedBy       User?     @relation("InvoiceApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  rejectionReason  String?   @db.Text

  driveFileId String?
  driveUrl    String?

  pohodaExportStatus    PohodaExportStatus @default(NONE)
  pohodaExportedAt      DateTime?
  pohodaExternalId      String?
  pohodaExportLastError String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueDate])
  @@index([supplierName])
  @@index([approvedAt])
  @@index([pohodaExportStatus])
}

model PaymentProof {
  id          String    @id @default(cuid())
  documentId  String    @unique
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  proofType   String?
  note        String?   @db.Text
  driveFileId String?
  driveUrl    String?
  storedAt    DateTime?

  paymentDate      DateTime?
  amount           Decimal?  @db.Decimal(12, 2)
  currency         String?   @default("CZK")
  counterpartyName String?
  counterpartyICO  String?
  variableSymbol   String?
  constantSymbol   String?
  specificSymbol   String?
  bankMessage      String?   @db.Text
  bankAccountNo    String?
  bankCode         String?

  pohodaExportStatus    PohodaExportStatus @default(NONE)
  pohodaExportedAt      DateTime?
  pohodaExternalId      String?
  pohodaExportLastError String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pohodaExportStatus])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model ProcessingJob {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  type        String
  status      String
  error       String?
  metadata    Json?
}

/// Skladová položka (zásoba). Aktuální stav v `quantity`, hlídání minima v `minQuantity`.
model InventoryItem {
  id          String   @id @default(cuid())
  /// Skladové / katalogové číslo (unikátní).
  sku         String   @unique
  name        String
  category    String?
  /// Měrná jednotka (ks, kg, l, m, …).
  unit        String   @default("ks")
  /// Aktuální stav na skladě (může být desetinné u vážených jednotek).
  quantity    Decimal  @default(0) @db.Decimal(14, 3)
  /// Minimální zásoba — pod ní se položka považuje za „nízkou".
  minQuantity Decimal? @db.Decimal(14, 3)
  /// Jednotková cena (pro výpočet hodnoty skladu).
  unitPrice   Decimal? @db.Decimal(12, 2)
  currency    String   @default("CZK")
  location    String?
  supplier    String?
  note        String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Původ položky. MANUAL = ruční; FULFILLMENT = řízeno synchronizací (stav nelze měnit ručně).
  source            InventorySource @default(MANUAL)
  /// Identifikátor v externím systému (u FULFILLMENT = variant_id z Fulfillment.cz).
  externalId        String?
  /// Dostupné množství (po odečtení rezervací) — plní synchronizace.
  availableQuantity Decimal?        @db.Decimal(14, 3)
  /// Rezervované množství — plní synchronizace.
  reservedQuantity  Decimal?        @db.Decimal(14, 3)
  /// Čas poslední úspěšné synchronizace z externího systému.
  lastSyncedAt      DateTime?

  movements InventoryMovement[]

  @@unique([source, externalId])
  @@index([active])
  @@index([category])
  @@index([name])
  @@index([source])
}

/// Pohyb na skladě (příjem / výdej / korekce). Mění `InventoryItem.quantity` a uchovává historii.
model InventoryMovement {
  id              String                @id @default(cuid())
  itemId          String
  item            InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type            InventoryMovementType
  /// Zadané množství pohybu (u IN/OUT množství pohybu, u ADJUSTMENT nový absolutní stav). Vždy >= 0.
  quantity        Decimal               @db.Decimal(14, 3)
  /// Stav skladu po provedení pohybu (audit).
  quantityAfter   Decimal               @db.Decimal(14, 3)
  note            String?               @db.Text
  createdByUserId String?
  createdBy       User?                 @relation("InventoryMovementCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())

  @@index([itemId])
  @@index([createdAt])
  @@index([type])
}
