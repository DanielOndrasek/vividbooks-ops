# --- Aplikace ---
# Lokální Docker: viz docker-compose.yml (port 5433).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/invoices?schema=public"
# Supabase / produkce: často přidej ?sslmode=require (nebo použij „Transaction pooler“ URI z dashboardu).
# Migrace proti produkci vždy lokálně: cd apps/web && npx prisma migrate deploy
AUTH_SECRET="vygeneruj-nahodny-retezec-min-32-znaku"
# Volitelný alias (Auth.js přijme místo AUTH_SECRET):
# NEXTAUTH_SECRET="stejna-hodnota"
# AUTH_DEBUG=1  # na Vercelu dočasně — detailnější auth logy
NEXTAUTH_URL="http://localhost:3000"
# Na Vercelu často pomůže i AUTH_URL=https://vase-domena.cz (stejná veřejná URL jako v prohlížeči).

# Google OAuth (NextAuth / přihlášení uživatelů)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

ALLOWED_EMAIL_DOMAIN=""

# --- Gmail ---
# Samostatný účet hr@vividbooks.com: v prohlížeči se při OAuth přihlas jako HR účet (nebo anonymní okno
# jen s ním), pak npm run gmail:token — GMAIL_REFRESH_TOKEN pak patří jen té schránce. GMAIL_DELIVERED_TO
# u takového účtu nepotřebuješ (nech prázdné); celá schránka „me“ jsou už jen faktury.
#
# Refresh token: npm run gmail:token
# V GCP u stejného Web OAuth klienta musí být redirect URI přesně:
#   http://127.0.0.1:47863/oauth2callback
# (localhost ≠ 127.0.0.1). Jiná varianta → nastav stejnou do GCP i sem:
# GMAIL_OAUTH_REDIRECT_URI=http://localhost:47863/oauth2callback
# GMAIL_CLIENT_ID=""
# GMAIL_CLIENT_SECRET=""
# GMAIL_REFRESH_TOKEN=""
# GMAIL_FILTER_LABEL=INBOX
# GMAIL_PROCESSED_LABEL=Zpracováno
# GMAIL_ONLY_UNREAD=1   # 1 = jen nepřečtené (výchozí), 0 = i přečtené v dosahu filtru
# GMAIL_DELIVERED_TO=hr@vividbooks.com   # jen u aliasu do jiné schránky; u samostatného HR účtu nechat prázdné
# GMAIL_ADDRESS_MATCH_MODE=deliveredto   # deliveredto (výchozí) | to
# GMAIL_POLL_MAX_RESULTS=25
# INVOICE_TMP_DIR=
# CRON_SECRET=""
# Po kolika dnech od schválení smazat fakturu z DB (zůstane na Drive). Výchozí 30.
# INVOICE_DB_RETENTION_DAYS=30
# Po prvním přihlášení: role v produkční DB (nejprve vercel env pull):
#   npm run db:set-role -- 'hello@vividbooks.com' ADMIN
# (Nepoužívej současně přepsání DATABASE_URL v lokálním .env — skript čte jen .env.vercel.production.)
# GMAIL_POLL_INTERVAL_MINUTES=5

# --- Google Drive (Shared Drive) ---
# POVINNĚ Google Shared Drive (sdílený disk). Service account nemá kvótu na osobním „Můj disk“.
# Postup:
#   1) Ve Workspace zřiďte sdílený disk.
#   2) E-mail service accountu z JSON (client_email) přidejte jako člena disku — např. Správce obsahu.
#   3) Na tomto disku vytvořte kořenové složky „FAKTURY“ / doklady platby (ne na Můj disk).
#   4) Do env dejte jejich folder ID (z URL …/folders/XXXX), ne ID celého disku.
# Viz: https://developers.google.com/workspace/drive/api/guides/about-shareddrives
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GOOGLE_DRIVE_INVOICES_FOLDER_ID=""
# GOOGLE_DRIVE_RECEIPTS_FOLDER_ID=""

# --- Anthropic / AI ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# AI_CONFIDENCE_THRESHOLD=0.7
# AI_BATCH_LIMIT=30

# --- Pipedrive (provize) ---
# PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_DOMAIN=vasa-firma (bez .pipedrive.com)
# PIPEDRIVE_CATEGORY_FIELD_KEY=  # volitelné — výchozí viz src/lib/integrations/env.ts

# --- Volitelně ---
# OPS_ADMIN_CONTACT=ops@vase-firma.cz
