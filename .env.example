# --- Integrace: Pipedrive (nástroj Provize a další) ---
PIPEDRIVE_API_TOKEN=your_api_token_here
PIPEDRIVE_DOMAIN=your_company_domain
# Product category (custom deal field). Vividbooks výchozí klíč je v kódu; pro přepsání:
# PIPEDRIVE_CATEGORY_FIELD_KEY=3f0c870ac132eec72589da1313e2388977c4a74f

# --- Streamlit hub: odkaz na webové doklady (Next.js v apps/web) ---
# DOKLADY_APP_URL=http://localhost:3000
# DOKLADY_ADMIN_CONTACT=ops@vase-firma.cz

# --- Integrace: RealityMIX (Supabase Edge Function + egress-realitymix worker) ---
# Worker apps/egress-realitymix běží na Fly.io s pevnou IPv4. Vyžaduje whitelist
# u DALTEN media (helpdesk@realitymix.cz) na náš REALITYMIX_SW_KEY.
# Tyto proměnné nastavit:
#   • v Supabase secrets (`supabase secrets set ...`) — používá Edge Function realitymix-sync
#   • ve Fly secrets (`flyctl secrets set ...`) — používá worker
#   • případně v lokálním .env workera pro vývoj s MOCK_MODE=true
# REALITYMIX_RK_ID=
# REALITYMIX_RK_PASSWORD=
# REALITYMIX_SW_KEY=
# INTERNAL_EGRESS_TOKEN=        # sdílené tajemství mezi Edge Function a workerem (≥ 32 znaků)
# EGRESS_BASE_URL=https://vividbooks-egress-realitymix.fly.dev
# HEALTHCHECKS_PING_URL=        # volitelné — externí monitoring (Healthchecks.io / Better Stack);
#                                 Edge Function ho pingne po každém běhu, suffix /fail při chybě.

# --- Budoucí integrace ---
# (další API klíče doplníme do vividbooks_ops/settings.py a této šablony)
